{
  "version": 2,
  "buildCommand": "npx prisma generate && npm run build",
  "builds": [
    {
      "src": "dist/lambda.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**", "node_modules/.prisma/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "dist/lambda.js" }
  ]
}
