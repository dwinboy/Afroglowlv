  "devDependencies": {
    "@nestjs/cli":          "^10.3.2",
    "@nestjs/testing":      "^10.3.8",
    "@types/bcrypt":        "^5.0.2",
    "@types/express":       "^4.17.21",
    "@types/multer":        "^1.4.11",
    "@types/nodemailer":    "^6.4.15",
    "@types/passport-jwt":  "^4.0.1",
    "@types/passport-local":"^1.0.38",
    "@types/qrcode":        "^1.5.5",
    "prisma":               "^5.15.0",
    "typescript":           "^5.4.5",
    "ts-node":              "^10.9.2",
    "jest":                 "^29.7.0",
    "@types/jest":          "^29.5.12",
    "ts-jest":              "^29.1.4"
  }
