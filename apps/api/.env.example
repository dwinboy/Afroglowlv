# ╔══════════════════════════════════════════════╗
# ║   AFROGLOW API — Environment Configuration    ║
# ║   Copy to .env and fill in your values        ║
# ╚══════════════════════════════════════════════╝

# ── Application ──────────────────────────────────────
NODE_ENV=production
PORT=4000
API_URL=https://api.yourdomain.com

# ── Frontend ─────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
# Optional comma-separated list of additional origins for CORS.
FRONTEND_URLS=https://your-app.vercel.app,https://www.yourdomain.com

# ── Database ─────────────────────────────────────────
# Neon pooled connection (recommended for runtime)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15
# Neon direct connection (recommended for Prisma migrate/introspect)
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/DBNAME?sslmode=require

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production

# ── SMTP Email ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@afroglow.lt
SMTP_PASS=your-app-specific-password
SMTP_FROM="Afroglow" <hello@afroglow.lt>

# ── Admin ────────────────────────────────────────────
ADMIN_EMAIL=admin@afroglow.lt

# ── Stripe (payments) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ── Cloudinary (file storage) ────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── WhatsApp (twilio) ────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Rate Limiting ────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
